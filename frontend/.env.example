# Frontend Configuration

# API URL Configuration
# In development: Leave empty to use Vite proxy (http://localhost:4000)
# In production: Use same origin and no hard-coded host.
# Leave blank to use relative API paths like /api.
VITE_API_URL=


# Supabase Configuration (if using Supabase for additional features)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PROJECT_ID=your-project-id
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
