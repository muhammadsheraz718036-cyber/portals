DATABASE_URL=postgres://username:password@localhost:5432/approval_center
JWT_SECRET=replace-with-at-least-32-random-characters
NODE_ENV=production
HOST=0.0.0.0
# Many hosts inject PORT automatically. Set it manually only for VPS/PM2/local deployments.
PORT=8080
# Set this to the real browser URL if your platform does not expose one automatically.
APP_BASE_URL=https://approvals.yourcompany.local
# Optional. Leave empty for same-origin deployments, or set comma-separated allowed origins.
CORS_ORIGIN=https://approvals.yourcompany.local
TRUST_PROXY=true
UPLOAD_DIR=storage/uploads
PG_SSL=false
PG_SSL_REJECT_UNAUTHORIZED=true
PG_CONNECTION_TIMEOUT_MS=10000
DB_POOL_MAX=20
EMAIL_NOTIFICATIONS_ENABLED=true
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Approval Central <notifications@yourdomain.com>"
EMAIL_PRIMARY_COLOR=#0f766e
