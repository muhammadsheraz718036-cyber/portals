{
  "name": "approval-central-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:frontend && npm run build:backend && npm run package:frontend",
    "build:frontend": "npm --prefix ../frontend run build",
    "build:backend": "tsc -p tsconfig.json",
    "package:frontend": "node scripts/copy-frontend-dist.mjs",
    "start": "node dist/index.js",
    "pm2:start": "node scripts/pm2-cli.mjs start ecosystem.config.cjs",
    "pm2:save": "node scripts/pm2-cli.mjs save",
    "pm2:status": "node scripts/pm2-cli.mjs status",
    "pm2:logs": "node scripts/pm2-cli.mjs logs approval-central",
    "db:schema": "tsx scripts/apply-schema.ts",
    "db:migrate": "tsx scripts/run-migrations.ts"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.13.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.11.10",
    "pm2": "^6.0.14",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
